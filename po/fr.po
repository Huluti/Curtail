msgstr "Préférences"

#: data/ui/preferences.blp:9
msgid "General"
msgstr "Général"

#: data/ui/preferences.blp:14
msgid "Safe Mode"
msgstr "Mode sécurisé"

#: data/ui/preferences.blp:15
